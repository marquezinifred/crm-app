# =====================================================================
# CRM B2B Multi-tenant — Environment Variables
#
# Copie para .env.local e preencha. NUNCA comite .env.local.
# Validação pelo Zod em src/lib/env.ts — campos sem `optional()`
# fazem o app falhar no boot quando ausentes.
# =====================================================================

NODE_ENV=development

# ---------------------------------------------------------------------
# Banco — Postgres com extensões pgvector, pgcrypto, citext
# (use a imagem pgvector/pgvector:pg16 do docker-compose.yml em dev)
# ---------------------------------------------------------------------
DATABASE_URL=postgresql://crm:crm_dev_password@localhost:5432/crm?schema=public

# Opcional — connection string com BYPASSRLS, usada por migrate e seed
# em produção. Em dev local, geralmente igual à DATABASE_URL.
# DIRECT_URL=postgresql://crm:crm_dev_password@localhost:5432/crm?schema=public

# ---------------------------------------------------------------------
# Clerk — auth (Google OAuth, Microsoft OAuth, magic link, TOTP 2FA)
#
# Para PROD / dev com Clerk real: gere as chaves em
# https://dashboard.clerk.com. A pub key precisa passar o parser do
# SDK — que valida (1) prefixo pk_test_/pk_live_ e (2) que o segmento
# do meio, quando base64-decoded, termina em `$`.
#
# Para dev/QA local SEM instância Clerk (bring-up rápido de worktrees,
# smoke test de `next dev`, Playwright E2E): use os dummies abaixo.
# Eles satisfazem o parser do SDK (a base64 decoda para
# `fake.clerk.accounts.dev$`), então `next dev` sobe e as páginas
# públicas renderizam. Rotas protegidas exigem login que falhará com
# 401 do Clerk API — combine com o bypass NODE_ENV=test em
# `/api/e2e/login` (tests/e2e/fixtures/auth.ts) para os E2E.
#
# NUNCA use os dummies em staging/produção — Zod passa (min(1)) mas
# qualquer chamada real ao Clerk API vai retornar `clerk_key_invalid`.
# ---------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_ZmFrZS5jbGVyay5hY2NvdW50cy5kZXYk
CLERK_SECRET_KEY=sk_test_dummy_do_not_use_in_prod
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# Clerk encryption key — silencia o warn "Missing CLERK_ENCRYPTION_KEY"
# emitido pelo SDK Clerk em `next dev`. Não é lida por `src/lib/env.ts`
# (Zod schema não conhece essa var), só pelo SDK diretamente. Complementa
# as dummies pub/secret acima. Em prod, gere real com:
#   openssl rand -base64 32
# A var não crasha o app quando ausente — só polui os logs de dev.
CLERK_ENCRYPTION_KEY=dev-only-clerk-encryption-key-32-bytes-min

# JWT template do Clerk deve incluir public.tenantId e public.role
# (configurado no dashboard Clerk no Sprint 1)

# ---------------------------------------------------------------------
# Redis — fila de jobs BullMQ
# ---------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------
# Anthropic — IA principal (Claude Haiku para resumos, Sonnet para análise)
# https://console.anthropic.com
# ---------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL_HAIKU=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_SONNET=claude-sonnet-4-6

# ---------------------------------------------------------------------
# Perplexity — benchmarks competitivos (Sprint posterior)
# https://docs.perplexity.ai
# ---------------------------------------------------------------------
PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------
# OpenAI — APENAS para embeddings da busca semântica (text-embedding-3-small)
# Sem isto, a busca cai para Postgres tsvector(portuguese) full-text search,
# que funciona razoavelmente bem em PT-BR mas sem semântica (sinônimos etc).
# ---------------------------------------------------------------------
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ---------------------------------------------------------------------
# Webhook inbound de e-mail (Postmark/Resend Inbound) — segredo via querystring
# Configure o provider para POST em /api/v1/inbound/email?secret=<este-valor>
# ---------------------------------------------------------------------
INBOUND_WEBHOOK_SECRET=gere-um-segredo-aleatorio

# ---------------------------------------------------------------------
# Web Push (notificações no celular). Gerar com:
#   npx web-push generate-vapid-keys
# Sem isto, push notifications ficam desabilitadas (UI esconde o botão).
# ---------------------------------------------------------------------
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_SUBJECT=mailto:noreply@suaempresa.com.br

# ---------------------------------------------------------------------
# Unleash (feature flags) — opcional, Sprint 10.5+
# Sem isto, flags caem para os defaults declarados em src/lib/feature-flags.ts
# ---------------------------------------------------------------------
UNLEASH_URL=https://us.app.unleash-hosted.com/.../api/
UNLEASH_API_TOKEN=*:development.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------
# Resend — disparo de e-mails (alertas, convites, magic links)
# https://resend.com
# ---------------------------------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM=crm@suaempresa.com.br

# ---------------------------------------------------------------------
# Storage — S3 ou R2 para uploads de propostas, contratos, NDAs
# (R2: https://developers.cloudflare.com/r2)
# ---------------------------------------------------------------------
S3_ENDPOINT=https://xxxxxxxxxxxxxxxx.r2.cloudflarestorage.com
S3_BUCKET=crm-documents
S3_REGION=auto
S3_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxx
S3_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------
# Stripe — billing de assinaturas SaaS (Sprint posterior)
# ---------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------
# Observabilidade — Sentry (erros) + Axiom (structured logs).
# Sem estes vars, SDKs viram no-op (dev local não precisa configurar).
# Ver docs/Observability.md pra setup completo.
# ---------------------------------------------------------------------
# Runtime
SENTRY_DSN=https://xxxxxxxxxxxxxxxx@oXXXXXX.ingest.sentry.io/XXXXXX
NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxxxxxxxxxxx@oXXXXXX.ingest.sentry.io/XXXXXX
SENTRY_ENVIRONMENT=development
# Build (upload sourcemap — opcional). Sem estas 3, build funciona mas
# stack traces em produção mostram código bundleado.
SENTRY_ORG=venzo
SENTRY_PROJECT=crm-app
SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxxxxxxxxxxxxxx

AXIOM_TOKEN=xaat-xxxxxxxxxxxxxxxxxxxxxxxx
AXIOM_DATASET=crm-app
# Logar queries tRPC além de mutations (default false — reduz custo Axiom)
AXIOM_LOG_QUERIES=false

# ---------------------------------------------------------------------
# App
# ---------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Chave (32+ chars) usada para encriptar a API key de IA por tenant
# (ai_api_key_encrypted). Gerar com: openssl rand -base64 32
TENANT_FIELD_ENCRYPTION_KEY=GERAR_COM_OPENSSL_RAND_BASE64_32_CHARS

# ---------------------------------------------------------------------
# Sprint 15G Fase 1a — Estrutura comercial hierárquica.
# Migration 0031 cria as tabelas + backfill de estrutura mínima por tenant.
# Flag desliga o consumo pela Fase 2 (resolveOpportunityScope) — enquanto
# false, visibilidade segue o path pré-15G. Ligar após Fase 2 mergear.
# Ver docs/Sprint_15G_amendments.md §A1.
# ---------------------------------------------------------------------
SALES_STRUCTURE_ENABLED=false

# ---------------------------------------------------------------------
# Sprint 15G.5 (T3) — Workflow de transferência de oportunidade.
# Migration 0032 cria opportunity_transfers (vazia). Flag false desliga o
# router de transferência, o guard de write (chip 2c) e o badge "Em
# transferência" (T16) — runtime idêntico ao pré-15G.5. Ligar após as
# fases 2/3 mergearem. Rollback = false sem redeploy.
# Ver docs/Sprint_15G5_Transferencia_Oportunidade.md §6.
# ---------------------------------------------------------------------
OPPORTUNITY_TRANSFER_ENABLED=false
